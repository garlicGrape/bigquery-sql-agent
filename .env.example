# Copy to .env and fill in real values. Never commit .env.
# LLM: Vertex AI uses Application Default Credentials — no separate API key needed.
# GCP credentials are managed via cloud-bootstrap (.cloud-credentials.<email>.enc).

# BigQuery / Vertex AI — same GCP project for billing
BQ_BILLING_PROJECT=msbai-dwd-sk7374
BQ_PROJECT_ID=bigquery-public-data
BQ_DATASET=new_york_citibike

# LangSmith tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=bigquery-sql-agent

# Tunables (optional — defaults shown)
# MODEL=gemini-2.5-flash
# VERTEX_LOCATION=us-central1
# MAX_RETRIES=3
# BYTE_CAP=10737418240
# DEFAULT_LIMIT=100
# MAX_RESULT_ROWS=50
