# Copy to .env and fill in real values. Never commit .env.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# BigQuery — use Application Default Credentials where possible instead of a key file.
# Run: gcloud auth application-default login
BQ_BILLING_PROJECT=your-gcp-project-id-here
BQ_PROJECT_ID=bigquery-public-data
BQ_DATASET=new_york_citibike

# LangSmith tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=bigquery-sql-agent

# Tunables (optional — defaults shown)
# MODEL=claude-sonnet-4-6
# MAX_RETRIES=3
# BYTE_CAP=10737418240
# DEFAULT_LIMIT=100
# MAX_RESULT_ROWS=50
